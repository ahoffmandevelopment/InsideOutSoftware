@page "/project/{ProjectId}"
@using System.Reflection
@using InsideOutSoftware.Web.Models
@using InsideOutSoftware.Web.Services
@inject ProjectService ProjectService

<div class="container mt-4">
    <div class="project-details">
        <div class="mb-3">
            <a href="/#projects" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i> Back to Projects
            </a>
        </div>

        @if (project is null)
        {
            <div class="project-not-found" role="status">
                <h1>Project not found</h1>
                <p>The requested project could not be found. Return to the projects section to browse the current portfolio.</p>
            </div>
        }
        else
        {
            <div class="project-details-header">
                <h1>@project.Title</h1>
                <p>@project.Description</p>
                @if (!string.IsNullOrWhiteSpace(project.Link))
                {
                    <a href="@project.Link" target="_blank" rel="noopener noreferrer" class="project-link">
                        <span>Visit Project</span>
                        <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                }
            </div>

            @if (project.Type == ProjectType.ImageGallery)
            {
                <div class="project-gallery">
                    <div class="gallery-grid">
                        @for (var i = 0; i < project.GalleryImages.Count; i++)
                        {
                            var image = project.GalleryImages[i];

                            <div class="gallery-item">
                                <img
                                    class="gallery-image @(project.Border ? "img-border" : string.Empty)"
                                    src="@ToAppRelativePath(image)"
                                    alt="@($"{project.Title} screenshot {i + 1}")" />
                            </div>
                        }
                    </div>
                </div>
            }
            else if (project.Type == ProjectType.WebComponent)
            {
                <div class="web-project-container">
                    @if (resolvedComponentType is not null)
                    {
                        <DynamicComponent Type="@resolvedComponentType" />
                    }
                    else
                    {
                        <div class="alert alert-warning" role="alert">
                            This project component is currently unavailable.
                        </div>
                    }
                </div>
            }
            else if (project.Type == ProjectType.HtmlProject && !string.IsNullOrWhiteSpace(project.ProjectUrl))
            {
                <div class="web-project-container">
                    <HtmlProject ProjectUrl="@project.ProjectUrl" Title="@project.Title" />
                </div>
            }
        }
    </div>
</div>

@code
{
    private ProjectModel? project;
    private Type? resolvedComponentType;

    [Parameter]
    public string ProjectId { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        project = ProjectService.GetProjectById(ProjectId);
        resolvedComponentType = project is not null && !string.IsNullOrWhiteSpace(project.ComponentName)
            ? GetComponentType(project.ComponentName)
            : null;
    }

    private static string ToAppRelativePath(string path) => $"/{path.TrimStart('/')}";

    private static Type? GetComponentType(string componentName)
    {
        var assembly = Assembly.GetExecutingAssembly();
        return assembly.GetType(componentName);
    }
}
